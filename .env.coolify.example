# ==========================================
# Take Machine - Coolify Environment Configuration Template
# ==========================================
# Copy this file to .env.coolify.local and populate with your real secrets.
# Do NOT commit .env.coolify.local to your repository.

# Database & Secrets (Set these locally in .env.coolify.local)
DATABASE_URL=SET_IN_COOLIFY_ONLY
ADMIN_PASSWORD=SET_IN_COOLIFY_ONLY
RSS_PREVIEW_TOKEN=SET_IN_COOLIFY_ONLY

# AI & Third-Party APIs (Set these locally in .env.coolify.local)
OPENAI_API_KEY=SET_IN_COOLIFY_ONLY
ELEVENLABS_API_KEY=SET_IN_COOLIFY_ONLY
ELEVENLABS_MAX_VOLTAGE_VOICE_ID=SET_IN_COOLIFY_ONLY
ELEVENLABS_DR_LINEBREAK_VOICE_ID=SET_IN_COOLIFY_ONLY
API_SPORTS_KEY=SET_IN_COOLIFY_ONLY

# Optional APIs (Uncomment and set in .env.coolify.local if needed)
# DEEPGRAM_API_KEY=SET_IN_COOLIFY_ONLY
# BALLDONTLIE_API_KEY=SET_IN_COOLIFY_ONLY
# THE_ODDS_API_KEY=SET_IN_COOLIFY_ONLY
# CARTESIA_API_KEY=SET_IN_COOLIFY_ONLY

# General Production Config (Pre-configured defaults)
NODE_ENV=production
APP_BASE_URL=https://podcast.hopwhistle.com
NEXT_PUBLIC_APP_BASE_URL=https://podcast.hopwhistle.com

# Redis Connection (Internal Coolify Redis URL)
REDIS_URL=redis://ydx8y0k0a3mm4zfwk196hiy4:6379

# Storage - Hetzner S3 Object Storage (Helsinki hel1)
STORAGE_PROVIDER=s3
S3_ENDPOINT=https://hel1.your-objectstorage.com
S3_REGION=hel1
S3_BUCKET=take-machine-media
S3_PUBLIC_BASE_URL=https://take-machine-media.hel1.your-objectstorage.com

# LLM Config
LLM_PROVIDER=openai
OPENAI_MODEL=gpt-5.5

# TTS Config
TTS_PROVIDER=elevenlabs
ELEVENLABS_MODEL=eleven_v3

# STT Config
STT_PROVIDER=deepgram
DEEPGRAM_MODEL=nova-3

# Sports & Odds Configs
SPORTS_PROVIDER=api-sports
NBA_PROVIDER=balldontlie
ODDS_PROVIDER=theoddsapi
NEWS_PROVIDER=rss
NEWS_RSS_FEEDS=https://www.espn.com/espn/rss/news,https://www.cbssports.com/rss/headlines/

# Podcast RSS Configurations
PODCAST_TITLE=Take Machine
PODCAST_DESCRIPTION=Sports debate shows built from real games, headlines, stats, and betting angles.
PODCAST_LANGUAGE=en-us
PODCAST_AUTHOR=Take Machine
PODCAST_OWNER_NAME=James Kelly
PODCAST_OWNER_EMAIL=jimmy@pvnvoice.com
PODCAST_SITE_URL=https://podcast.hopwhistle.com
PODCAST_RSS_URL=https://podcast.hopwhistle.com/rss
PODCAST_IMAGE_URL=https://take-machine-media.hel1.your-objectstorage.com/assets/take-machine-cover.png
PODCAST_CATEGORY=Sports
PODCAST_SUBCATEGORY=Sports News
PODCAST_EXPLICIT=false
PODCAST_COPYRIGHT=Copyright 2026 Take Machine
PODCAST_TTL=60

RSS_INCLUDE_TRANSCRIPT_LINK=true
RSS_INCLUDE_SHOW_NOTES=true

# Media Processing Gaps
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe
AUDIO_LINE_GAP_MS=450
AUDIO_SEGMENT_GAP_MS=850
AUDIO_TOPIC_GAP_MS=1200

# Concurrency (Conservative settings for shared Hetzner Server)
WORKER_CONCURRENCY=1
TTS_WORKER_CONCURRENCY=1
AUDIO_STITCH_WORKER_CONCURRENCY=1
CONTENT_WORKER_CONCURRENCY=1
RSS_WORKER_CONCURRENCY=1

# Security
TRUST_PROXY=true
COOKIE_SECURE=true
