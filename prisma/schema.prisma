datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  name          String?
  role          String    @default("USER")
  // Monetization tier (Step 9c). Additive, defaults to "free" for every existing
  // + new account. This single column is the entitlement source of truth a
  // future billing webhook would update — no processor is wired in this step.
  plan          String    @default("free")
  // --- Auth.js additions (all additive/nullable; existing columns unchanged) ---
  emailVerified DateTime? // set when the user confirms their email (email flow is stubbed until a mail provider is configured)
  image         String?   // avatar URL (from OAuth or account settings)
  passwordHash  String?   // bcrypt hash for the Credentials provider; null for OAuth-only accounts
  accounts      Account[]
  sessions      Session[]
  podcasts      Podcast[] // shows this user owns
  episodes      Episode[] // episodes this user created
  aiHosts       AiHost[]  // Character Studio hosts this user owns (null owner = shared)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// --- Auth.js (NextAuth v5) / @auth/prisma-adapter standard tables ---
// Sessions use the JWT strategy (Credentials provider requires it), so the
// Session table is present for adapter compatibility but not the primary
// session store. OAuth (Google) links accounts here.
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model AiHost {
  id               String   @id @default(uuid())
  name             String
  slug             String   @unique
  role             String
  worldview        String
  speakingStyle    String
  catchphrases     Json     // Array of strings
  likes            Json     // Array of strings
  dislikes         Json     // Array of strings
  argumentPatterns Json     // Array of strings or objects
  bannedPhrases    Json     // Array of strings
  ttsProvider      String
  ttsVoiceId       String
  intensityLevel   Int
  isActive         Boolean  @default(true)
  // Soft archive (Step 8 Character Studio): archived hosts drop out of active
  // pickers but keep their association with existing episodes. Additive +
  // default false (migration 20260707140000).
  isArchived       Boolean  @default(false)
  // Per-account ownership (additive, nullable, migration 20260707150000).
  // null = system/shared host (existing rows + seed) — visible read-only to
  // every account; non-null = owned by that User.id. Pickers show own + shared;
  // mutations are owner-gated; the resolver stays owner-agnostic.
  ownerId          String?
  ownerUser        User?    @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  // Documented voice provenance — the legal-safety fields (cf. Greene v. Google).
  // voiceSource: "owned" | "licensed" | "synthetic" | "cloned" (free-text for now).
  // voiceProvenanceNote: license id / consent record / source documentation.
  // Surfacing + editing is Step 8; the columns exist now so provenance can be
  // recorded. Additive + nullable (migration 20260707130000).
  voiceSource         String?
  voiceProvenanceNote String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model SportsDataSource {
  id            String    @id @default(uuid())
  name          String    @unique
  type          String
  baseUrl       String
  isActive      Boolean   @default(true)
  lastIngestedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model League {
  id              String           @id // Custom ID e.g. "NBA", "NFL"
  name            String
  sport           String
  slug            String           @unique
  isActive        Boolean          @default(true)
  teams           Team[]
  players         Player[]
  games           Game[]
  teamStats       TeamStat[]
  playerStats     PlayerStat[]
  topicCandidates TopicCandidate[]
}

model Team {
  id           String       @id // Custom ID e.g. "BOS", "KC"
  leagueId     String
  name         String
  city         String
  abbreviation String
  slug         String       @unique
  league       League       @relation(fields: [leagueId], references: [id])
  players      Player[]
  homeGames    Game[]       @relation("HomeTeam")
  awayGames    Game[]       @relation("AwayTeam")
  teamStats    TeamStat[]
  playerStats  PlayerStat[]
  injuries     Injury[]

  @@index([leagueId])
}

model Player {
  id          String       @id
  leagueId    String
  teamId      String?
  name        String
  position    String?
  status      String?
  league      League       @relation(fields: [leagueId], references: [id])
  team        Team?        @relation(fields: [teamId], references: [id])
  playerStats PlayerStat[]
  injuries    Injury[]

  @@index([leagueId])
  @@index([teamId])
}

model Game {
  id             String          @id
  leagueId       String
  homeTeamId     String
  awayTeamId     String
  scheduledAt    DateTime
  status         String
  homeScore      Int?
  awayScore      Int?
  sourceId       String?
  raw            Json
  league         League          @relation(fields: [leagueId], references: [id])
  homeTeam       Team            @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam       Team            @relation("AwayTeam", fields: [awayTeamId], references: [id])
  oddsSnapshots  OddsSnapshot[]

  @@index([leagueId])
  @@index([homeTeamId])
  @@index([awayTeamId])
  @@index([scheduledAt])
}

model TeamStat {
  id         String   @id @default(uuid())
  teamId     String
  leagueId   String
  season     String
  statType   String
  value      Json
  sourceId   String?
  recordedAt DateTime
  team       Team     @relation(fields: [teamId], references: [id])
  league     League   @relation(fields: [leagueId], references: [id])

  @@index([teamId])
  @@index([leagueId])
  @@index([season, statType])
}

model PlayerStat {
  id         String   @id @default(uuid())
  playerId   String
  teamId     String?
  leagueId   String
  season     String
  statType   String
  value      Json
  sourceId   String?
  recordedAt DateTime
  player     Player   @relation(fields: [playerId], references: [id])
  team       Team?    @relation(fields: [teamId], references: [id])
  league     League   @relation(fields: [leagueId], references: [id])

  @@index([playerId])
  @@index([teamId])
  @@index([leagueId])
  @@index([season, statType])
}

model Injury {
  id          String   @id @default(uuid())
  playerId    String
  teamId      String?
  status      String?
  description String?
  reportedAt  DateTime
  sourceId    String?
  sourceUrl   String?
  player      Player   @relation(fields: [playerId], references: [id])
  team        Team?    @relation(fields: [teamId], references: [id])

  @@index([playerId])
  @@index([teamId])
}

model OddsSnapshot {
  id                 String   @id @default(uuid())
  gameId             String
  sportsbook         String
  market             String
  line               Float?
  price              Float?
  impliedProbability Float?
  capturedAt         DateTime
  sourceId           String?
  raw                Json
  game               Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@index([gameId])
  @@index([sportsbook])
  @@index([capturedAt])
}

model NewsItem {
  id          String   @id @default(uuid())
  title       String
  source      String
  url         String
  publishedAt DateTime
  summary     String?
  entities    Json     // Array of extracted entities/keywords
  raw         Json
  
  @@index([publishedAt])
}

// Editorial-readiness lifecycle for a topic candidate. Deliberately does NOT
// include a "used" state: usage is derived from EpisodeTopic.
enum TopicEditorialStatus {
  pending
  approved
  rejected
  archived
}

model TopicCandidate {
  id                    String         @id @default(uuid())
  title                 String
  sport                 String
  leagueId              String?
  summary               String?
  controversyScore      Float
  starPowerScore        Float
  bettingRelevanceScore Float
  recencyScore          Float
  debateScore           Float
  evidenceIds           Json           // Structured logs linking back to Games/Stats/News
  // EDITORIAL READINESS ONLY — never a global usage flag. Usage is derived from
  // EpisodeTopic (a topic can be consumed by many users/podcasts/episodes).
  // Enforced at the DB level as an enum so "used"/arbitrary values can't be
  // written through Prisma.
  status                TopicEditorialStatus
  createdAt             DateTime       @default(now())
  league                League?        @relation(fields: [leagueId], references: [id])
  researchBrief         ResearchBrief?
  episodeTopics         EpisodeTopic[]

  @@index([leagueId])
  @@index([status])
  @@index([createdAt])
}

model ResearchBrief {
  id                String         @id @default(uuid())
  topicId           String         @unique
  facts             Json           // Scraped facts/bulletpoints
  stats             Json           // Relevant statistics
  injuryContext     String?
  oddsContext       String?
  argumentForHostA  String
  argumentForHostB  String
  counterArguments  Json           // Counter arguments structure
  unsafeClaims      Json           // Moderated/flagged points
  sourceIds         Json           // List of source URLs/IDs
  createdAt         DateTime       @default(now())
  topic             TopicCandidate @relation(fields: [topicId], references: [id], onDelete: Cascade)

  // Decoupled editorial fields
  classification    String?
  mainAngle         String?
  whyMattersNow     String?
  keyFactsContext   Json?
  onAirTalkingPoints Json?
  contrarianAngle   String?
  strongestDebateQuestion String?
  suggestedHostTake String?
  sourceNotesUsed   String?
}

// A user-defined show: the saved recipe (verticals, teams, hosts, segment
// count, cadence) that episodes are generated from — one-time or recurring.
model Podcast {
  id            String   @id @default(uuid())
  name          String
  cadence       String   // "one_time" | "recurring"
  scheduleDays  String[] @default([]) // ["mon".."sun"] — recurring only
  verticals     String[] @default([]) // display names from src/lib/verticals.ts (e.g. "NFL", "College Football")
  teams         String[] @default([]) // Team.id values; empty = vertical-wide
  segmentCount  Int      @default(3)  // maps to the pipeline's targetTopicCount
  hostIds       String[] @default([]) // AiHost.id values
  owner         String   @default("listener") // legacy free-text owner; superseded by ownerId
  ownerId       String?  // User.id of the creator; null for legacy/pre-auth podcasts
  ownerUser     User?    @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  // "YYYY-MM-DD" in the scheduler TZ — atomic idempotency claim so a re-run
  // of the daily scheduler never double-generates (see recurring scheduler).
  lastAutoGeneratedDate String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  episodes      Episode[]

  @@index([cadence])
  @@index([ownerId])
}

model Episode {
  id                 String         @id @default(uuid())
  title              String
  slug               String         @unique
  status             String         // "draft" | "queued" | "generating" | "completed" | "failed"
  description        String?
  longShowNotes      String?
  durationSeconds    Int?
  audioUrl           String?
  transcriptUrl      String?
  rssGuid            String?        @unique
  publishedAt        DateTime?
  episodeNumber      Int?
  seasonNumber       Int?
  explicit           Boolean        @default(false)
  rssSummary         String?
  rssSubtitle        String?
  rssImageUrl        String?
  audioFileSizeBytes Int?
  audioMimeType      String         @default("audio/mpeg")
  ttsProvider        String?        // Voice engine chosen at build time ("fish", "boson", ...); null = fall through to host/env. See docs/TTS_PROVIDERS.md
  ttsVoiceOverrides  Json?          // Per-host voice picks keyed by host slug: { "max-voltage": { provider, voiceId, voiceName? }, ... }. See docs/TTS_PROVIDERS.md
  soundDesign        Json?          // Post-production settings: { style, sfxDensity, highlights: [{lineIndex, assetId}] }. See docs/SOUND_DESIGN.md
  podcastId          String?        // Nullable — pre-existing episodes have no podcast
  ownerId            String?        // User.id of the creator; null for legacy/pre-auth episodes
  hostIds            String[]       @default([]) // AiHost.id pair cast at build time; empty = default duo (Max Voltage / Dr. Linebreak)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  podcast            Podcast?       @relation(fields: [podcastId], references: [id], onDelete: SetNull)
  ownerUser          User?          @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  topics             EpisodeTopic[]
  scripts            Script[]
  audioSegments      AudioSegment[]
  socialClips        SocialClip[]
  playEvents         PlayEvent[]

  @@index([status])
  @@index([publishedAt])
  @@index([podcastId])
  @@index([ownerId])
}

model EpisodeTopic {
  id         String         @id @default(uuid())
  episodeId  String
  topicId    String
  orderIndex Int
  // IMMUTABLE snapshot of the topic + research brief AS SELECTED, so an episode
  // stays reproducible even if the source topic/brief is later edited. Shape:
  // src/lib/services/topicSnapshot.ts EpisodeTopicSnapshot. Nullable for legacy
  // rows until the backfill runs; readers fall back to live topic data.
  snapshot   Json?
  // When this topic was selected into the episode — also the "used" timestamp
  // that derived usage + cooldown policies read.
  selectedAt DateTime       @default(now())
  episode    Episode        @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  topic      TopicCandidate @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@unique([episodeId, topicId])
  @@index([episodeId])
  @@index([topicId])
  @@index([selectedAt])
}

model Script {
  id               String            @id @default(uuid())
  episodeId        String
  version          Int
  content          Json              // Lines format: [{hostId, text, stageDirection}]
  plainText        String?
  status           String            // "draft" | "generating" | "ready" | "failed"
  createdAt        DateTime          @default(now())
  episode          Episode           @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  factCheckResults FactCheckResult[]
  audioSegments    AudioSegment[]

  @@index([episodeId])
  @@index([status])
}

model FactCheckResult {
  id               String   @id @default(uuid())
  scriptId         String
  passed           Boolean
  warnings         Json     // Array of warning objects
  errors           Json     // Array of error objects
  createdAt        DateTime @default(now())
  script           Script   @relation(fields: [scriptId], references: [id], onDelete: Cascade)
  episodeId        String?
  status           String   @default("needs_review") // "passed" | "failed" | "needs_review"
  checkedAt        DateTime @default(now())
  provider         String   @default("deterministic")
  summary          Json?
  issues           Json?
  evidenceCoverage Json?
  rawResult        Json?

  @@index([scriptId])
}

model AudioSegment {
  id         String   @id @default(uuid())
  episodeId  String
  scriptId   String
  hostId     String?  // References host profile who spoke it
  lineIndex  Int
  text       String
  audioUrl   String?
  durationMs Int?
  status           String   // "pending" | "processing" | "ready" | "failed"
  provider         String?
  providerMetadata Json?
  createdAt        DateTime @default(now())
  episode          Episode  @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  script           Script   @relation(fields: [scriptId], references: [id], onDelete: Cascade)

  @@index([episodeId])
  @@index([scriptId])
  @@index([lineIndex])
}

// Managed post-production audio asset (theme, stinger, music bed, SFX,
// cleared game highlight). Every asset carries its license; game highlights
// additionally require an explicit rights affirmation before they can be
// mixed into an episode.
model AudioAsset {
  id              String   @id @default(uuid())
  name            String
  kind            String   // "theme_intro" | "theme_outro" | "stinger" | "bed" | "sfx" | "highlight"
  category        String?  // sfx flavor: "laugh" | "crowd" | "airhorn" | "buzzer" | "rimshot" | "whoosh" | "impact"
  tags            Json     // string[]
  audioUrl        String
  storageKey      String?
  durationMs      Int?
  license         String   // e.g. "Original (generated in-house), CC0" | "Licensed — see note"
  licenseNote     String?
  rightsConfirmed Boolean  @default(false) // must be true for kind "highlight" to be usable
  isActive        Boolean  @default(true)
  source          String   @default("upload") // "seed" | "upload"
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([kind])
  @@index([isActive])
}

// Singleton (id = "default"): which assets voice the show's produced sound,
// plus the default production style / SFX density for new episodes.
model SoundDesignConfig {
  id                String   @id @default("default")
  themeIntroAssetId String?
  themeOutroAssetId String?
  bedAssetId        String?
  stingerAssetIds   Json?    // string[] — rotated deterministically between breaks
  defaultStyle      String   @default("full")   // "clean" | "light" | "full"
  defaultSfxDensity String   @default("subtle") // "subtle" | "medium" | "hype"
  updatedAt         DateTime @updatedAt
}

// One row per sound asset a rendered episode consumed (stingers, beds,
// reaction SFX). The production planner reads the last N episodes' rows as
// its anti-repetition cooldown; rows are rewritten atomically when an
// episode re-renders so re-runs never double-count.
model SoundCueUsage {
  id        String   @id @default(uuid())
  episodeId String
  scriptId  String?
  assetId   String
  assetName String?
  cueType   String   // "stinger" | "bed_change" | "reaction"
  usedAt    DateTime @default(now())

  @@index([assetId, usedAt])
  @@index([episodeId])
  @@index([usedAt])
}

model JobLog {
  id        String   @id @default(uuid())
  jobType   String
  status    String
  input     Json
  output    Json
  error     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([jobType])
  @@index([status])
  @@index([createdAt])
}

// IAB-style download/listen analytics (Step 9b). Privacy-first: NO raw IP or
// PII is ever stored — only a truncated salted hash of (ip + user-agent) used
// solely for dedup, a coarse app bucket derived from the user-agent, and a
// 2-letter country ONLY when the edge/proxy supplies a geo header. IAB dedup:
// the @@unique on (episodeId, clientHash, dayBucket, kind) collapses repeat
// requests from the same client for the same episode within a UTC-day window
// (range requests / re-fetches) to a single counted event. Additive
// (migration 20260708130000). ownerId is denormalized from Episode for
// owner-scoped queries; cascade cleans up on episode delete.
model PlayEvent {
  id         String   @id @default(uuid())
  episodeId  String
  ownerId    String?  // Episode.ownerId at record time; null for legacy episodes
  kind       String   // "download" | "play"
  source     String   // "rss" | "direct" | "player"
  clientHash String   // sha256(ip + ua + daily salt), truncated — never the raw IP
  country    String?  // 2-letter ISO, only when a geo header is present; else null
  appBucket  String?  // coarse client bucket from UA (Apple Podcasts, Spotify, Web, …)
  dayBucket  String   // UTC "YYYY-MM-DD" — the IAB dedup window
  at         DateTime @default(now())
  episode    Episode  @relation(fields: [episodeId], references: [id], onDelete: Cascade)

  @@unique([episodeId, clientHash, dayBucket, kind])
  @@index([ownerId, at])
  @@index([episodeId, kind])
}

// Auto social clip — a short vertical (9:16) captioned promo cut of an episode's
// spiciest exchange. Selection reuses the real transcript tone/energy; the clip
// audio is rendered from the real per-line AudioSegment audio via the same
// ffmpeg path the full stitch uses. Additive (migration 20260708120000).
model SocialClip {
  id             String   @id @default(uuid())
  episodeId      String
  scriptId       String
  ownerId        String?  // creator (Episode.ownerId); null for legacy episodes
  startLineIndex Int
  endLineIndex   Int
  title          String?
  status         String   @default("pending") // pending | rendering | ready | failed
  kind           String?  // "video" (9:16 mp4) | "audio+captions" (mp3 + vtt fallback)
  audioUrl       String?  // always produced (real episode audio)
  videoUrl       String?  // 9:16 burned-caption mp4 when the ffmpeg build allows it
  captionsUrl    String?  // WebVTT caption track (host-colour cues)
  durationMs     Int?
  autoSelected   Boolean  @default(false)
  error          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  episode        Episode  @relation(fields: [episodeId], references: [id], onDelete: Cascade)

  @@index([episodeId])
  @@index([ownerId])
}
