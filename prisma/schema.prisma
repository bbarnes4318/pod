datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  name          String?
  role          String    @default("USER")
  // Monetization tier (Step 9c). Additive, defaults to "free" for every existing
  // + new account. This single column is the entitlement source of truth a
  // future billing webhook would update — no processor is wired in this step.
  plan          String    @default("free")
  // --- Auth.js additions (all additive/nullable; existing columns unchanged) ---
  emailVerified DateTime? // set when the user confirms their email (email flow is stubbed until a mail provider is configured)
  image         String?   // avatar URL (from OAuth or account settings)
  passwordHash  String?   // bcrypt hash for the Credentials provider; null for OAuth-only accounts
  accounts      Account[]
  sessions      Session[]
  podcasts      Podcast[] // shows this user owns
  episodes      Episode[] // episodes this user created
  aiHosts       AiHost[]  // Character Studio hosts this user owns (null owner = shared)
  audioAssets   AudioAsset[] @relation("OwnedAudioAssets") // private sound library
  studioDraft   StudioDraft? // in-progress Studio rundown (pre-generation resume state)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// --- Auth.js (NextAuth v5) / @auth/prisma-adapter standard tables ---
// Sessions use the JWT strategy (Credentials provider requires it), so the
// Session table is present for adapter compatibility but not the primary
// session store. OAuth (Google) links accounts here.
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model AiHost {
  id               String   @id @default(uuid())
  name             String
  slug             String   @unique
  role             String
  worldview        String
  speakingStyle    String
  catchphrases     Json     // Array of strings
  likes            Json     // Array of strings
  dislikes         Json     // Array of strings
  argumentPatterns Json     // Array of strings or objects
  bannedPhrases    Json     // Array of strings
  ttsProvider      String
  ttsVoiceId       String
  intensityLevel   Int
  isActive         Boolean  @default(true)
  // Soft archive (Step 8 Character Studio): archived hosts drop out of active
  // pickers but keep their association with existing episodes. Additive +
  // default false (migration 20260707140000).
  isArchived       Boolean  @default(false)
  // Per-account ownership (additive, nullable, migration 20260707150000).
  // null = system/shared host (existing rows + seed) — visible read-only to
  // every account; non-null = owned by that User.id. Pickers show own + shared;
  // mutations are owner-gated; the resolver stays owner-agnostic.
  ownerId          String?
  ownerUser        User?    @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  // Declared so the schema matches what 20260707150000_add_aihost_owner actually
  // built. The pickers filter hosts by owner, so this index is wanted — it was
  // simply never written down here, which showed up as drift the moment a
  // database was rebuilt from migrations. See 20260715170000_reconcile_aihost_owner.
  // Documented voice provenance — the legal-safety fields (cf. Greene v. Google).
  // voiceSource: "owned" | "licensed" | "synthetic" | "cloned" (free-text for now).
  // voiceProvenanceNote: license id / consent record / source documentation.
  // Surfacing + editing is Step 8; the columns exist now so provenance can be
  // recorded. Additive + nullable (migration 20260707130000).
  voiceSource         String?
  voiceProvenanceNote String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  castMemberships  EpisodeCastMember[]

  @@index([ownerId])
}

// Normalized episode cast (Prompt 7): WHICH host sits in WHICH chair of the
// episode's show format. Replaces the bare two-slot Episode.hostIds pair
// assumption (that column stays as a legacy mirror in seat order). Seat 0..3;
// role ids come from the format registry (chair_a, anchor, moderator, ...).
model EpisodeCastMember {
  id         String   @id @default(uuid())
  episodeId  String
  episode    Episode  @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  hostId     String
  host       AiHost   @relation(fields: [hostId], references: [id], onDelete: Restrict)
  role       String   // ShowFormatRole.id from the registry
  orderIndex Int      // seat order: drives speaking order, seating, colors
  createdAt  DateTime @default(now())

  @@unique([episodeId, orderIndex])
  @@unique([episodeId, hostId])
  @@index([hostId])
}

model SportsDataSource {
  id            String    @id @default(uuid())
  name          String    @unique
  type          String
  baseUrl       String
  isActive      Boolean   @default(true)
  lastIngestedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model League {
  id              String           @id // Custom ID e.g. "NBA", "NFL"
  name            String
  sport           String
  slug            String           @unique
  isActive        Boolean          @default(true)
  teams           Team[]
  players         Player[]
  games           Game[]
  teamStats       TeamStat[]
  playerStats     PlayerStat[]
  topicCandidates TopicCandidate[]
}

model Team {
  id           String       @id // Custom ID e.g. "BOS", "KC"
  leagueId     String
  name         String
  city         String
  abbreviation String
  slug         String       @unique
  league       League       @relation(fields: [leagueId], references: [id])
  players      Player[]
  homeGames    Game[]       @relation("HomeTeam")
  awayGames    Game[]       @relation("AwayTeam")
  teamStats    TeamStat[]
  playerStats  PlayerStat[]
  injuries     Injury[]

  @@index([leagueId])
}

model Player {
  id          String       @id
  leagueId    String
  teamId      String?
  name        String
  position    String?
  status      String?
  league      League       @relation(fields: [leagueId], references: [id])
  team        Team?        @relation(fields: [teamId], references: [id])
  playerStats PlayerStat[]
  injuries    Injury[]

  @@index([leagueId])
  @@index([teamId])
}

model Game {
  id             String          @id
  leagueId       String
  homeTeamId     String
  awayTeamId     String
  scheduledAt    DateTime
  status         String
  homeScore      Int?
  awayScore      Int?
  sourceId       String?
  raw            Json
  league         League          @relation(fields: [leagueId], references: [id])
  homeTeam       Team            @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam       Team            @relation("AwayTeam", fields: [awayTeamId], references: [id])
  oddsSnapshots  OddsSnapshot[]

  @@index([leagueId])
  @@index([homeTeamId])
  @@index([awayTeamId])
  @@index([scheduledAt])
}

model TeamStat {
  id         String   @id @default(uuid())
  teamId     String
  leagueId   String
  season     String
  statType   String
  value      Json
  sourceId   String?
  recordedAt DateTime
  team       Team     @relation(fields: [teamId], references: [id])
  league     League   @relation(fields: [leagueId], references: [id])

  @@index([teamId])
  @@index([leagueId])
  @@index([season, statType])
}

model PlayerStat {
  id         String   @id @default(uuid())
  playerId   String
  teamId     String?
  leagueId   String
  season     String
  statType   String
  value      Json
  sourceId   String?
  recordedAt DateTime
  player     Player   @relation(fields: [playerId], references: [id])
  team       Team?    @relation(fields: [teamId], references: [id])
  league     League   @relation(fields: [leagueId], references: [id])

  @@index([playerId])
  @@index([teamId])
  @@index([leagueId])
  @@index([season, statType])
}

model Injury {
  id          String   @id @default(uuid())
  playerId    String
  teamId      String?
  status      String?
  description String?
  reportedAt  DateTime
  sourceId    String?
  sourceUrl   String?
  player      Player   @relation(fields: [playerId], references: [id])
  team        Team?    @relation(fields: [teamId], references: [id])

  @@index([playerId])
  @@index([teamId])
}

model OddsSnapshot {
  id                 String   @id @default(uuid())
  gameId             String
  sportsbook         String
  market             String
  line               Float?
  price              Float?
  impliedProbability Float?
  capturedAt         DateTime
  sourceId           String?
  raw                Json
  game               Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@index([gameId])
  @@index([sportsbook])
  @@index([capturedAt])
}

model NewsItem {
  id          String   @id @default(uuid())
  title       String
  source      String
  url         String
  publishedAt DateTime
  summary     String?
  entities    Json     // Array of extracted entities/keywords
  raw         Json
  
  @@index([publishedAt])
}

// Editorial-readiness lifecycle for a topic candidate. Deliberately does NOT
// include a "used" state: usage is derived from EpisodeTopic.
enum TopicEditorialStatus {
  pending
  approved
  rejected
  archived
}

model TopicCandidate {
  id                    String         @id @default(uuid())
  title                 String
  sport                 String
  leagueId              String?
  summary               String?
  controversyScore      Float
  starPowerScore        Float
  bettingRelevanceScore Float
  recencyScore          Float
  debateScore           Float
  evidenceIds           Json           // Structured logs linking back to Games/Stats/News
  // EDITORIAL READINESS ONLY — never a global usage flag. Usage is derived from
  // EpisodeTopic (a topic can be consumed by many users/podcasts/episodes).
  // Enforced at the DB level as an enum so "used"/arbitrary values can't be
  // written through Prisma.
  status                TopicEditorialStatus
  createdAt             DateTime       @default(now())
  league                League?        @relation(fields: [leagueId], references: [id])
  researchBrief         ResearchBrief?
  episodeTopics         EpisodeTopic[]
  sources               TopicSource[]  // operator-imported articles (editorial input, NOT evidence)

  @@index([leagueId])
  @@index([status])
  @@index([createdAt])
}

// An article an operator imported by URL as editorial STARTING MATERIAL for a
// topic. Deliberately NOT evidence: nothing here is verified, so importing a
// source never touches TopicCandidate.evidenceIds (which the pipeline writes
// only after existence-checking each ref) and never satisfies a research gate.
// A topic with sources but no research still reports missing evidence/brief.
//
// WHY A NEW MODEL: NewsItem is the RSS ingest artifact — it has no topic
// relation, no content hash, no fetch outcome, no canonical URL, no importing
// operator, and is read by topic generation. Writing operator imports into it
// would both lose the fields below and quietly feed the automatic topic
// generator. Injury.sourceUrl is the only other URL column and is unrelated.
model TopicSource {
  id           String    @id @default(uuid())
  topicId      String
  // As pasted (minus any credentials, which are rejected before we get here).
  originalUrl  String
  // Post-redirect, normalized. The duplicate-detection key.
  canonicalUrl String
  title        String?
  publisher    String?
  author       String?
  publishedAt  DateTime?
  // Sanitized PLAIN TEXT only. Raw HTML is never stored: it has no consumer,
  // and storing it would keep an XSS payload alive in the database.
  excerpt      String?
  // sha256 of the fetched body — cheap change detection without keeping it.
  contentHash  String?
  // "imported" | one of the FetchErrorCategory values.
  fetchStatus  String
  fetchErrorCategory String?
  retrievedAt  DateTime?
  // adminIdentity() — an audit label, NOT a User FK (admins have no User row).
  createdByAdminIdentity String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  topic TopicCandidate @relation(fields: [topicId], references: [id], onDelete: Cascade)

  // The same article can't be imported onto the same topic twice.
  @@unique([topicId, canonicalUrl])
  @@index([topicId])
  @@index([canonicalUrl])
}

model ResearchBrief {
  id                String         @id @default(uuid())
  topicId           String         @unique
  facts             Json           // Scraped facts/bulletpoints
  stats             Json           // Relevant statistics
  injuryContext     String?
  oddsContext       String?
  argumentForHostA  String
  argumentForHostB  String
  counterArguments  Json           // Counter arguments structure
  unsafeClaims      Json           // Moderated/flagged points
  sourceIds         Json           // List of source URLs/IDs
  createdAt         DateTime       @default(now())
  topic             TopicCandidate @relation(fields: [topicId], references: [id], onDelete: Cascade)

  // Decoupled editorial fields
  classification    String?
  mainAngle         String?
  whyMattersNow     String?
  keyFactsContext   Json?
  onAirTalkingPoints Json?
  contrarianAngle   String?
  strongestDebateQuestion String?
  suggestedHostTake String?
  sourceNotesUsed   String?
}

// A user-defined show: the saved recipe (verticals, teams, hosts, segment
// count, cadence) that episodes are generated from — one-time or recurring.
model Podcast {
  id            String   @id @default(uuid())
  name          String
  cadence       String   // "one_time" | "recurring"
  scheduleDays  String[] @default([]) // ["mon".."sun"] — recurring only
  verticals     String[] @default([]) // display names from src/lib/verticals.ts (e.g. "NFL", "College Football")
  teams         String[] @default([]) // Team.id values; empty = vertical-wide
  segmentCount  Int      @default(3)  // maps to the pipeline's targetTopicCount
  hostIds       String[] @default([]) // AiHost.id values
  owner         String   @default("listener") // legacy free-text owner; superseded by ownerId
  ownerId       String?  // User.id of the creator; null for legacy/pre-auth podcasts
  ownerUser     User?    @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  // "YYYY-MM-DD" in the scheduler TZ — atomic idempotency claim so a re-run
  // of the daily scheduler never double-generates (see recurring scheduler).
  lastAutoGeneratedDate String?

  // --- Canonical show identity (Prompt 5) --------------------------------
  // A show is a saved, versioned configuration. These fields are the show's
  // public identity; the editorial/production/publishing *settings* live in
  // the three 1-1 config tables below. See docs/PODCAST_CONFIGURATION.md.
  slug          String?  @unique // URL-safe, normalized, reserved-name-rejecting; null only until backfilled
  description   String?
  author        String?  // shown as the RSS <itunes:author> / channel author
  ownerName     String?  // owner display name (distinct from the legacy free-text `owner`)
  ownerEmail    String?  // SENSITIVE: contact email for the feed owner. Never returned by list APIs and never written into an Episode snapshot.
  websiteUrl    String?
  language      String   @default("en") // RSS channel language (BCP-47)
  category      String?  // Apple Podcasts primary category
  subcategory   String?  // Apple Podcasts subcategory
  explicit      Boolean  @default(false) // channel-level explicit default
  copyright     String?
  coverImageUrl String?
  visibility    String   @default("private") // "private" | "unlisted" | "public" — private != token feed; see Prompt 8 (deferred)
  // Bumped on every accepted configuration change (optimistic concurrency).
  configVersion Int      @default(1)

  editorialConfig  PodcastEditorialConfig?
  productionConfig PodcastProductionConfig?
  publishingConfig PodcastPublishingConfig?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  episodes      Episode[]
  audioAssets   AudioAsset[] // podcast-private sound assets

  @@index([cadence])
  @@index([ownerId])
  @@index([visibility])
}

// One-to-one editorial settings: WHAT a show covers and HOW its script is shaped.
// Kept normalized (not JSON) so the resolver validates each field and migrations
// can reason about them. See docs/PODCAST_CONFIGURATION.md.
model PodcastEditorialConfig {
  id            String   @id @default(uuid())
  podcastId     String   @unique
  podcast       Podcast  @relation(fields: [podcastId], references: [id], onDelete: Cascade)
  verticals     String[] @default([]) // mirrors Podcast.verticals during transition; resolver reads this
  teams         String[] @default([]) // Team.id values
  segmentCount  Int      @default(3)  // pipeline targetTopicCount
  format        String   @default("two_host_debate") // ONLY two_host_debate is supported (Prompt 7 deferred)
  minDebateScore Int?    // real TopicCandidate.debateScore floor; null = pipeline default
  scriptStyle   String?  // Advanced Producer scriptStyle (real)
  maxWords      Int?     // Advanced Producer maxWords (real)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// One-to-one production settings: voices and post-production.
model PodcastProductionConfig {
  id                String   @id @default(uuid())
  podcastId         String   @unique
  podcast           Podcast  @relation(fields: [podcastId], references: [id], onDelete: Cascade)
  hostIds           String[] @default([]) // AiHost.id values; generation supports at most 2
  ttsProvider       String?  // voice engine override; null = fall through host/env
  ttsVoiceOverrides Json?    // per-host voice picks, same shape as Episode.ttsVoiceOverrides
  productionStyle   String?  // sound design style: "clean" | "light" | "full"
  sfxDensity        String?  // sound design sfx density

  // --- Sound profile (Prompt 6) ------------------------------------------
  // "system_default": the shared system profile, FROZEN into each Episode's
  //   snapshot at creation (a later system edit never changes that Episode).
  // "custom": this Podcast's explicit PodcastSoundAssignment rows.
  // "clean": dialogue only — no intro/outro/bed/stingers/reactions.
  soundProfileMode          String  @default("system_default")
  targetLoudnessLufs        Float?  // master loudness target; null = pipeline default (-16)
  // Cue anti-repetition scope: "podcast" (default — only THIS show's prior
  // usage counts) or "owner" (all of this owner's shows). NEVER global:
  // another customer's usage must not influence this show's rotation.
  cooldownScope             String  @default("podcast")
  stingerCooldownEpisodes   Int?    // null = pipeline default
  reactionCooldownEpisodes  Int?    // null = pipeline default
  defaultIntroEnabled       Boolean @default(true)
  defaultOutroEnabled       Boolean @default(true)

  // --- Sonic identity (PR 2) ---------------------------------------------
  // The producer's declared, versioned creative identity for THIS show
  // (validated JSON: genre/moods/pace/intensity/broadcastStyle, allowed &
  // prohibited cue families, format restrictions, bed & voice-over-music
  // policy, music-gap bounds). null = the permissive default (unchanged
  // behavior). See src/lib/audio/sonicIdentity.ts.
  sonicIdentity             Json?

  soundAssignments PodcastSoundAssignment[]
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// Normalized Podcast sound assignment (Prompt 6; VARIANT POOLS in PR 2): which
// asset voices which role for a show. As of PR 2 EVERY role (intro/outro/bed/
// stinger/reaction) is a POOL of weighted, ordered VARIANTS — the old
// one-enabled-intro/outro/bed singleton index is dropped so a show can rotate
// among a coherent brand family. Entries are still deduped per
// (podcast, role, asset). A variant carries a cue family, a bounded weight, an
// optional branded-motif flag, per-episode use/cooldown limits, and optional
// per-assignment format allow/deny lists.
model PodcastSoundAssignment {
  id           String  @id @default(uuid())
  productionConfigId String
  productionConfig   PodcastProductionConfig @relation(fields: [productionConfigId], references: [id], onDelete: Cascade)
  podcastId    String  // denormalized for direct scoping queries + constraints
  assetId      String
  asset        AudioAsset @relation(fields: [assetId], references: [id], onDelete: Restrict)
  role         String  // "intro" | "outro" | "bed" | "stinger" | "reaction"
  orderIndex   Int     @default(0) // deterministic pool ordering
  enabled      Boolean @default(true)
  gainDb       Float?  // bounded trim; null = neutral
  fadeInMs     Int?
  fadeOutMs    Int?
  // --- Variant pool metadata (PR 2) --------------------------------------
  cueFamily          String?  // creative purpose (see sonicIdentity.ts); must be valid for role
  weight             Float    @default(1) // bounded [0,100]; deterministic selection weight
  isBrandedMotif     Boolean  @default(false)
  maxUsesPerEpisode  Int?     // null = pipeline default
  minEpisodeCooldown Int?     // null = pipeline default
  allowedFormatIds   String[] @default([]) // empty = all formats
  prohibitedFormatIds String[] @default([])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([podcastId, role, assetId]) // no duplicate pool entries
  @@index([podcastId, role])
  @@index([podcastId, role, enabled])
  @@index([assetId])
}

// One row per audio RENDER of an episode (Prompt 6): initial mix, reproduce,
// or remix. The Podcast configuration snapshot says what was PERMITTED; this
// record (plus its SoundCueUsage rows) says what actually HAPPENED — and a
// later asset/profile edit can never rewrite it.
model EpisodeAudioRender {
  id                       String    @id @default(uuid())
  episodeId                String
  episode                  Episode   @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  scriptId                 String?
  renderVersion            Int       // 1, 2, ... per episode
  status                   String    // "running" | "succeeded" | "failed"
  renderMode               String    // "initial" | "reproduce" | "remix_episode_profile" | "remix_current_podcast" | "legacy"
  plannerSeed              Int?
  productionStyle          String?
  sfxDensity               String?
  targetLoudnessLufs       Float?
  configurationFingerprint String?   // Episode configuration fingerprint at render time
  plan                     Json?     // the exact ProductionPlan executed — the reproduce-mode source of truth
  diagnostics              Json?     // safe per-render cue-sheet report (RenderDiagnostics) — names/ids/reasons/bookend result only, never URLs/keys
  outputAudioUrl           String?   // final master reference (existing Episode.audioUrl value)
  failureReason            String?   // safe category only — never URLs/keys/commands
  startedAt                DateTime  @default(now())
  completedAt              DateTime?
  createdAt                DateTime  @default(now())
  usages                   SoundCueUsage[]

  @@unique([episodeId, renderVersion])
  @@index([episodeId])
  @@index([status])
}

// One-to-one publishing policy: which auto-assets are produced and whether
// downloads are enabled. Channel metadata (title/language/category/explicit)
// lives on Podcast; this table is per-show publishing behavior. Nothing here
// enables private feeds (Prompt 8 deferred) — /rss stays as-is.
model PodcastPublishingConfig {
  id                   String   @id @default(uuid())
  podcastId            String   @unique
  podcast              Podcast  @relation(fields: [podcastId], references: [id], onDelete: Cascade)
  autoGenerateChapters Boolean  @default(true)
  autoGenerateShowNotes Boolean @default(true)
  autoGenerateCover    Boolean  @default(true)
  includeTranscript    Boolean  @default(true)
  downloadsEnabled     Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model Episode {
  id                 String         @id @default(uuid())
  title              String
  slug               String         @unique
  status             String         // "draft" | "queued" | "generating" | "completed" | "failed"
  description        String?
  longShowNotes      String?
  durationSeconds    Int?
  audioUrl           String?
  transcriptUrl      String?
  rssGuid            String?        @unique
  publishedAt        DateTime?
  episodeNumber      Int?
  seasonNumber       Int?
  explicit           Boolean        @default(false)
  rssSummary         String?
  rssSubtitle        String?
  rssImageUrl        String?
  audioFileSizeBytes Int?
  audioMimeType      String         @default("audio/mpeg")
  ttsProvider        String?        // Voice engine chosen at build time ("fish", "boson", ...); null = fall through to host/env. See docs/TTS_PROVIDERS.md
  ttsVoiceOverrides  Json?          // Per-host voice picks keyed by host slug: { "max-voltage": { provider, voiceId, voiceName? }, ... }. See docs/TTS_PROVIDERS.md
  soundDesign        Json?          // Post-production settings: { style, sfxDensity, highlights: [{lineIndex, assetId}] }. See docs/SOUND_DESIGN.md
  podcastId          String?        // Nullable — pre-existing episodes have no podcast
  ownerId            String?        // User.id of the creator; null for legacy/pre-auth episodes
  hostIds            String[]       @default([]) // LEGACY compat: AiHost.id list in seat order; canonical cast = castMembers (Prompt 7)
  // --- Show format (Prompt 7) --------------------------------------------
  // Which registered format built this episode. two_host_debate is the
  // backfilled value for every pre-format episode — that IS what built them.
  formatId           String         @default("two_host_debate")
  castMembers        EpisodeCastMember[]
  // --- Immutable configuration snapshot (Prompt 5) -----------------------
  // Frozen at creation so a later edit to the Podcast can never rewrite how a
  // finished episode was built. See src/lib/services/episodeConfigurationSnapshot.ts.
  configurationSource         String  @default("legacy") // "podcast" | "standalone" | "legacy"
  podcastConfigurationVersion Int?    // Podcast.configVersion captured at snapshot time (podcast episodes only)
  configurationSnapshot       Json?   // versioned, deterministic, secret-free resolved config
  configurationFingerprint    String? // sha256 of the canonicalized snapshot
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  podcast            Podcast?       @relation(fields: [podcastId], references: [id], onDelete: SetNull)
  ownerUser          User?          @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  topics             EpisodeTopic[]
  scripts            Script[]
  audioSegments      AudioSegment[]
  socialClips        SocialClip[]
  audioRenders       EpisodeAudioRender[]

  playEvents         PlayEvent[]

  @@index([status])
  @@index([publishedAt])
  @@index([podcastId])
  @@index([ownerId])
}

model EpisodeTopic {
  id         String         @id @default(uuid())
  episodeId  String
  topicId    String
  orderIndex Int
  // IMMUTABLE snapshot of the topic + research brief AS SELECTED, so an episode
  // stays reproducible even if the source topic/brief is later edited. Shape:
  // src/lib/services/topicSnapshot.ts EpisodeTopicSnapshot. Nullable for legacy
  // rows until the backfill runs; readers fall back to live topic data.
  snapshot   Json?
  // When this topic was selected into the episode — also the "used" timestamp
  // that derived usage + cooldown policies read.
  selectedAt DateTime       @default(now())
  episode    Episode        @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  topic      TopicCandidate @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@unique([episodeId, topicId])
  @@index([episodeId])
  @@index([topicId])
  @@index([selectedAt])
}

// Durable, cross-session resume state for the Studio multi-topic rundown BUILDER
// (pre-generation: before an Episode exists). Stores the full editor state so a
// producer can close the tab / switch machines and resume with every topic,
// ordering, mode, host, and production setting intact. One active draft per
// user; cleared once the episode is created. NEVER holds a generated episode's
// immutable topic snapshots — those live on EpisodeTopic.
model StudioDraft {
  id        String   @id @default(uuid())
  ownerId   String   @unique // one resumable Studio rundown per user
  state     Json     // RundownDraftState (src/lib/services/studioDraft.ts)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ownerUser User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
}

// Resumable ADMIN rundown. Deliberately NOT a StudioDraft row and deliberately
// WITHOUT a User relation: /admin authenticates via HTTP Basic Auth against
// env vars (src/lib/adminAuth.ts adminIdentity()), so an admin operator has no
// User row to foreign-key against. StudioDraft.ownerId is a REQUIRED FK to
// User(id), so reusing it for an admin identity would fail at insert. This
// follows the JobLog precedent: operator-authored state keyed by the audited
// admin identity string, carrying the SAME RundownDraftState JSON blob Studio
// persists (src/lib/services/studioDraft.ts) so the two surfaces cannot drift.
model AdminDraft {
  id        String   @id @default(uuid())
  adminId   String   @unique // adminIdentity() — one resumable rundown per operator
  state     Json     // RundownDraftState (same schema as StudioDraft.state)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([updatedAt])
}

model Script {
  id               String            @id @default(uuid())
  episodeId        String
  version          Int
  content          Json              // Lines format: [{hostId, text, stageDirection}]
  plainText        String?
  status           String            // "draft" | "generating" | "ready" | "failed"
  createdAt        DateTime          @default(now())
  episode          Episode           @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  factCheckResults FactCheckResult[]
  audioSegments    AudioSegment[]

  @@index([episodeId])
  @@index([status])
}

model FactCheckResult {
  id               String   @id @default(uuid())
  scriptId         String
  passed           Boolean
  warnings         Json     // Array of warning objects
  errors           Json     // Array of error objects
  createdAt        DateTime @default(now())
  script           Script   @relation(fields: [scriptId], references: [id], onDelete: Cascade)
  episodeId        String?
  status           String   @default("needs_review") // "passed" | "failed" | "needs_review"
  checkedAt        DateTime @default(now())
  provider         String   @default("deterministic")
  summary          Json?
  issues           Json?
  evidenceCoverage Json?
  rawResult        Json?

  @@index([scriptId])
}

model AudioSegment {
  id         String   @id @default(uuid())
  episodeId  String
  scriptId   String
  hostId     String?  // References host profile who spoke it
  lineIndex  Int
  text       String
  audioUrl   String?
  durationMs Int?
  status           String   // "pending" | "processing" | "ready" | "failed"
  provider         String?
  providerMetadata Json?
  createdAt        DateTime @default(now())
  episode          Episode  @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  script           Script   @relation(fields: [scriptId], references: [id], onDelete: Cascade)

  @@index([episodeId])
  @@index([scriptId])
  @@index([lineIndex])
}

// Managed post-production audio asset (theme, stinger, music bed, SFX,
// cleared game highlight). Every asset carries its license; game highlights
// additionally require an explicit rights affirmation before they can be
// mixed into an episode.
model AudioAsset {
  id              String   @id @default(uuid())
  name            String
  kind            String   // "theme_intro" | "theme_outro" | "stinger" | "bed" | "sfx" | "highlight"
  category        String?  // sfx flavor: "laugh" | "crowd" | "airhorn" | "buzzer" | "rimshot" | "whoosh" | "impact"
  tags            Json     // string[]
  audioUrl        String   // LEGACY compat read path; new code resolves via storageKey + provider
  storageKey      String?
  durationMs      Int?
  license         String   // LEGACY free-text; superseded by licenseStatus/licenseName below
  licenseNote     String?
  rightsConfirmed Boolean  @default(false) // LEGACY boolean; superseded by rightsStatus below
  isActive        Boolean  @default(true)
  source          String   @default("upload") // "seed" | "upload"

  // --- Ownership scope (Prompt 6) ----------------------------------------
  // "shared_system"   admin-managed library, usable by everyone (ownerId/podcastId null)
  // "owner_private"   belongs to one User (ownerId set, podcastId null)
  // "podcast_private" belongs to one owned Podcast (ownerId + podcastId set, owners must match)
  // "legacy_global"   pre-Prompt-6 asset of ambiguous ownership: admin-only,
  //                   blocked from NEW selection until classified. The column
  //                   default is deliberately this fail-closed value so an
  //                   insert that forgets scope can never widen access.
  // NOTE: a "workspace" scope belongs to Prompt 13 (Workspaces) — do NOT add
  // it here; until then assets are user-owned, podcast-associated, or shared.
  scope                    String  @default("legacy_global")
  ownerId                  String? // User.id — required for owner_private/podcast_private
  ownerUser                User?    @relation("OwnedAudioAssets", fields: [ownerId], references: [id], onDelete: SetNull)
  podcastId                String? // Podcast.id — required for podcast_private only
  podcast                  Podcast? @relation(fields: [podcastId], references: [id], onDelete: SetNull)
  uploadedByUserId         String? // audit: who performed the upload (plain id, not authority)
  createdByAdminIdentity   String? // audit: admin identity for shared_system assets
  legacyScopeReviewRequired Boolean @default(false) // true = admin must classify before new use

  // --- Immutable media content (Prompt 6) ---------------------------------
  // Once processingStatus = "ready", contentHash/storageKey/bytes are frozen
  // (a DB trigger enforces this): replacing audio creates a NEW asset that
  // supersedes this one, so historical snapshots and renders stay auditable.
  contentHash        String? // sha256 of the media bytes; null only for unrepaired legacy rows
  originalFilename   String? // display-only; NEVER used as a storage path
  mimeType           String?
  fileSizeBytes      Int?
  sampleRate         Int?
  channelCount       Int?
  bitrateKbps        Int?
  processingStatus   String  @default("ready") // "uploading" | "processing" | "ready" | "failed"
  processingError    String? // safe category only — never commands/paths/URLs
  supersededByAssetId String?
  supersededByAsset  AudioAsset?  @relation("AudioAssetSupersession", fields: [supersededByAssetId], references: [id], onDelete: SetNull)
  supersedes         AudioAsset[] @relation("AudioAssetSupersession")

  // --- Archive (never hard-delete an asset with history) ------------------
  isArchived    Boolean   @default(false)
  archivedAt    DateTime?
  archiveReason String?

  // --- License + rights (Prompt 6; structured, replaces the loose strings) --
  licenseStatus              String    @default("unknown") // "original" | "licensed" | "public_domain" | "cc0" | "unknown" | "restricted" | "expired" | "revoked"
  licenseName                String?
  licenseReference           String?
  rightsStatus               String    @default("not_required") // "not_required" | "pending" | "confirmed" | "rejected" | "expired" | "revoked"
  rightsNotes                String?
  allowedUse                 String?   // e.g. "podcast_production"; enforced for restricted assets
  rightsConfirmedAt          DateTime?
  rightsConfirmedByUserId    String?
  rightsConfirmedByAdminIdentity String?
  rightsExpiresAt            DateTime?
  rightsDocumentStorageKey   String?   // PRIVATE — never in DTOs/logs; served only via an authorized route

  // --- Cue metadata (PR 2) -----------------------------------------------
  // Admin-reviewed creative metadata (cue family, genre, mood, energy,
  // instrumentation, and per-slot suitability). Structured JSON so no new
  // musical facts are fabricated: `metadataState` gates authority —
  // "unclassified" (none), "suggested" (proposed, NOT authoritative), or
  // "verified" (admin-confirmed, usable for HARD compatibility decisions).
  // See src/lib/audio/cueMetadata.ts.
  cueMetadata     Json?
  metadataState   String   @default("unclassified") // "unclassified" | "suggested" | "verified"

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  auditEvents     AudioAssetAuditEvent[]
  soundAssignments PodcastSoundAssignment[]

  @@index([kind])
  @@index([isActive])
  @@index([scope])
  @@index([ownerId])
  @@index([podcastId])
  @@index([contentHash])
  @@index([metadataState])
}

// Immutable per-asset audit trail (Prompt 6). Append-only: nothing in the
// application updates or deletes rows here; hard-deleting an asset (allowed
// only for failed/unreferenced uploads) cascades its events away with it.
model AudioAssetAuditEvent {
  id            String   @id @default(uuid())
  assetId       String
  asset         AudioAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  event         String   // created | upload_completed | metadata_extracted | metadata_failed |
                         // license_updated | rights_confirmed | rights_revoked | assigned_to_podcast |
                         // removed_from_podcast | archived | restored | superseded | classified | rendered
  actorType     String   // "user" | "admin" | "system"
  userId        String?
  adminIdentity String?
  podcastId     String?
  metadata      Json?    // SAFE fields only — never secrets/URLs/storage keys/rights docs
  createdAt     DateTime @default(now())

  @@index([assetId, createdAt])
  @@index([event])
}

// Singleton (id = "default"): which assets voice the show's produced sound,
// plus the default production style / SFX density for new episodes.
model SoundDesignConfig {
  id                String   @id @default("default")
  themeIntroAssetId String?
  themeOutroAssetId String?
  bedAssetId        String?
  stingerAssetIds   Json?    // string[] — rotated deterministically between breaks
  defaultStyle      String   @default("full")   // "clean" | "light" | "full"
  defaultSfxDensity String   @default("subtle") // "subtle" | "medium" | "hype"
  updatedAt         DateTime @updatedAt
}

// One row per sound asset a rendered episode consumed (stingers, beds,
// reaction SFX). The production planner reads the last N episodes' rows as
// its anti-repetition cooldown; rows are rewritten atomically when an
// episode re-renders so re-runs never double-count.
model SoundCueUsage {
  id        String   @id @default(uuid())
  episodeId String
  scriptId  String?
  assetId   String
  assetName String?
  cueType   String   // "stinger" | "bed_change" | "reaction" | "theme_intro" | "theme_outro" | "highlight"
  usedAt    DateTime @default(now())

  // --- Ownership + render provenance (Prompt 6) ---------------------------
  // Cooldown reads are scoped by podcastId (default) or ownerId — NEVER
  // global — and every row snapshots the asset facts at use time so a later
  // asset edit/archive cannot rewrite render history. Legacy rows (before
  // this migration) carry selectionSource "legacy" and nulls where the truth
  // is unknown; the backfill fills owner/podcast from the Episode only.
  renderId          String?
  render            EpisodeAudioRender? @relation(fields: [renderId], references: [id], onDelete: SetNull)
  ownerId           String?
  podcastId         String?
  assetKind         String?
  assetScope        String?
  assetContentHash  String?
  lineIndex         Int?
  timelinePositionMs Int?
  orderIndex        Int?
  gainDb            Float?
  fadeInMs          Int?
  fadeOutMs         Int?
  selectionSource   String  @default("legacy") // "podcast_assignment" | "system_default" | "production_planner" | "episode_highlight" | "historical_reproduction" | "legacy"

  @@index([assetId, usedAt])
  @@index([episodeId])
  @@index([usedAt])
  @@index([podcastId, usedAt])
  @@index([ownerId, usedAt])
  @@index([renderId])
}

model JobLog {
  id        String   @id @default(uuid())
  jobType   String
  status    String
  input     Json
  output    Json
  error     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([jobType])
  @@index([status])
  @@index([createdAt])
}

// IAB-style download/listen analytics (Step 9b). Privacy-first: NO raw IP or
// PII is ever stored — only a truncated salted hash of (ip + user-agent) used
// solely for dedup, a coarse app bucket derived from the user-agent, and a
// 2-letter country ONLY when the edge/proxy supplies a geo header. IAB dedup:
// the @@unique on (episodeId, clientHash, dayBucket, kind) collapses repeat
// requests from the same client for the same episode within a UTC-day window
// (range requests / re-fetches) to a single counted event. Additive
// (migration 20260708130000). ownerId is denormalized from Episode for
// owner-scoped queries; cascade cleans up on episode delete.
model PlayEvent {
  id         String   @id @default(uuid())
  episodeId  String
  ownerId    String?  // Episode.ownerId at record time; null for legacy episodes
  kind       String   // "download" | "play"
  source     String   // "rss" | "direct" | "player"
  clientHash String   // sha256(ip + ua + daily salt), truncated — never the raw IP
  country    String?  // 2-letter ISO, only when a geo header is present; else null
  appBucket  String?  // coarse client bucket from UA (Apple Podcasts, Spotify, Web, …)
  dayBucket  String   // UTC "YYYY-MM-DD" — the IAB dedup window
  at         DateTime @default(now())
  episode    Episode  @relation(fields: [episodeId], references: [id], onDelete: Cascade)

  @@unique([episodeId, clientHash, dayBucket, kind])
  @@index([ownerId, at])
  @@index([episodeId, kind])
}

// Auto social clip — a short vertical (9:16) captioned promo cut of an episode's
// spiciest exchange. Selection reuses the real transcript tone/energy; the clip
// audio is rendered from the real per-line AudioSegment audio via the same
// ffmpeg path the full stitch uses. Additive (migration 20260708120000).
model SocialClip {
  id             String   @id @default(uuid())
  episodeId      String
  scriptId       String
  ownerId        String?  // creator (Episode.ownerId); null for legacy episodes
  startLineIndex Int
  endLineIndex   Int
  title          String?
  status         String   @default("pending") // pending | rendering | ready | failed
  kind           String?  // "video" (9:16 mp4) | "audio+captions" (mp3 + vtt fallback)
  audioUrl       String?  // always produced (real episode audio)
  videoUrl       String?  // 9:16 burned-caption mp4 when the ffmpeg build allows it
  captionsUrl    String?  // WebVTT caption track (host-colour cues)
  durationMs     Int?
  autoSelected   Boolean  @default(false)
  error          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  episode        Episode  @relation(fields: [episodeId], references: [id], onDelete: Cascade)

  @@index([episodeId])
  @@index([ownerId])
}
