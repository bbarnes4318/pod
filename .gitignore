# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example
!.env.production.example
!.env.coolify.example
.env.coolify.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# generated A/B audio samples
/samples/*
# ...except the shipped planner variety-harness artifacts (cue sheets,
# report, before/after renders) - regenerable via npm run demo:sound-variety
!/samples/planner-variety/
ingest-assets/

# Epidemic ingest runtime report (contains prod asset ids)
ingest-report.json
_es_payload.json

# local StorageProvider output (dev fallback for S3)
/public/storage/

# Playwright e2e transient auth state
tests/e2e/.auth/
test-results/
playwright-report/
