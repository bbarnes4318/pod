# Database Configuration
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/takemachine?schema=public&connect_timeout=2"

# Redis Configuration (For BullMQ)
REDIS_URL="redis://localhost:6379"

# S3-Compatible Object Storage
STORAGE_PROVIDER="stub"
S3_ENDPOINT="http://localhost:9000" # Local minio or AWS S3 endpoint
S3_ACCESS_KEY_ID="minioadmin"
S3_SECRET_ACCESS_KEY="minioadmin"
S3_BUCKET_NAME="takemachine-audio"
S3_REGION="us-east-1"

# Provider Configurations
# LLM Provider: 'openai' | 'anthropic' | 'stub'
LLM_PROVIDER="stub"
OPENAI_API_KEY="your-openai-api-key"
OPENAI_MODEL="gpt-4o-mini"
ANTHROPIC_API_KEY="your-anthropic-api-key"
ANTHROPIC_MODEL="claude-3-5-sonnet-latest"

# TTS Provider: 'elevenlabs' | 'cartesia' | 'stub'
TTS_PROVIDER="stub"
ELEVENLABS_API_KEY="your-elevenlabs-api-key"
CARTESIA_API_KEY="your-cartesia-api-key"

# Sports Data Provider: 'sportsdataio' | 'oddsapi' | 'stub'
SPORTS_PROVIDER="stub"
SPORTSDATAIO_API_KEY="your-sportsdataio-api-key"
THEODDSAPI_API_KEY="your-theoddsapi-api-key"
RSS_NEWS_FEEDS="https://www.espn.com/espn/rss/news"

# Next.js Port (optional)
PORT=3000

# TTS and Audio configurations
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
CARTESIA_MODEL_ID=sonic-2
OPENAI_TTS_MODEL=gpt-4o-mini-tts
TTS_AUDIO_FORMAT=mp3
TTS_AUDIO_BUCKET="takemachine-audio"
TTS_MAX_CONCURRENT_REQUESTS=2
TTS_RETRY_ATTEMPTS=3

# FFmpeg & Audio Stitching configurations
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe
AUDIO_STITCH_TEMP_DIR=/tmp/take-machine-audio
AUDIO_OUTPUT_FORMAT=mp3
AUDIO_TARGET_BITRATE=192k
AUDIO_TARGET_SAMPLE_RATE=44100
AUDIO_TARGET_CHANNELS=2
AUDIO_LINE_GAP_MS=450
AUDIO_SEGMENT_GAP_MS=850
AUDIO_TOPIC_GAP_MS=1200
AUDIO_NORMALIZE=true
AUDIO_TARGET_LUFS=-16
AUDIO_INTRO_URL=
AUDIO_OUTRO_URL=
AUDIO_BED_URL=
