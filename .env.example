# Database Configuration
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/takemachine?schema=public&connect_timeout=2"

# Redis Configuration (For BullMQ)
REDIS_URL="redis://default:password@localhost:6379"

# S3-Compatible Object Storage
STORAGE_PROVIDER="stub"
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY_ID="minioadmin"
S3_SECRET_ACCESS_KEY="minioadmin"
S3_BUCKET_NAME="takemachine-audio"
S3_REGION="us-east-1"
S3_PUBLIC_BASE_URL="http://localhost:9000/takemachine-audio"

# Provider Configurations
LLM_PROVIDER="stub"
OPENAI_API_KEY="your-openai-api-key"
OPENAI_MODEL="gpt-4o-mini"
ANTHROPIC_API_KEY="your-anthropic-api-key"
ANTHROPIC_MODEL="claude-3-5-sonnet-latest"

RESEARCH_PROVIDER="stub"
EXA_API_KEY="your-exa-api-key"

TTS_PROVIDER="stub"
ELEVENLABS_API_KEY="your-elevenlabs-api-key"
CARTESIA_API_KEY="your-cartesia-api-key"

# Boson AI TTS (TTS_PROVIDER="boson") — lines are wrapped with Boson inline
# control tokens (<|emotion:X|>, <|prosody:X|>, <|sfx:X|>) automatically.
BOSON_API_KEY="your-boson-api-key"
BOSON_TTS_MODEL="higgs-tts-3"
BOSON_TTS_VOICE="default"
# Optional per-host voice overrides:
# BOSON_MAX_VOLTAGE_VOICE_ID=""
# BOSON_DR_LINEBREAK_VOICE_ID=""
# Optional voice cloning reference:
# BOSON_TTS_REF_AUDIO=""
# BOSON_TTS_REF_TEXT=""

# Fish Audio TTS (TTS_PROVIDER="fish") — lines get inline natural-language
# [bracket] cues automatically. FISH_MODEL: s2.1-pro-free (dev/testing, $0
# fair-use) or s2.1-pro (production).
FISH_API_KEY="your-fish-audio-api-key"
FISH_MODEL="s2.1-pro-free"
# Optional voice ids (Fish reference_id); omit for the default voice:
# FISH_TTS_VOICE=""
# FISH_MAX_VOLTAGE_VOICE_ID=""
# FISH_DR_LINEBREAK_VOICE_ID=""

SPORTS_PROVIDER="oddsapi"
ODDS_API_KEY=""
NEWS_PROVIDER="rss"
# Comma-separated news feeds. Leave UNSET to use the verified sport-specific
# defaults (ESPN/CBS/Yahoo per-league feeds — see DEFAULT_NEWS_RSS_FEEDS in
# src/lib/env.ts). Setting this OVERRIDES the defaults entirely.
NEWS_RSS_FEEDS=""

# Podcast RSS & Feed Configurations
PODCAST_TITLE="Take Machine"
PODCAST_DESCRIPTION="AI-powered sports debate podcasts built from approved, fact-checked sports research."
PODCAST_LANGUAGE="en-us"
PODCAST_AUTHOR="Take Machine"
PODCAST_OWNER_NAME="Take Machine"
PODCAST_OWNER_EMAIL="owner@takemachine.com
PODCAST_SITE_URL="http://localhost:3000"
PODCAST_RSS_URL="http://localhost:3000/rss"
PODCAST_IMAGE_URL="http://localhost:3000/storage/podcast-cover.jpg"
PODCAST_CATEGORY="Sports"
PODCAST_SUBCATEGORY="Sports News"
PODCAST_EXPLICIT="false"
PODCAST_COPYRIGHT="Copyright Take Machine"
PODCAST_TTL="60"
RSS_INCLUDE_TRANSCRIPT_LINK="true"
RSS_INCLUDE_SHOW_NOTES="true"
RSS_PREVIEW_TOKEN="super-secret-preview-token"

# Media
FFMPEG_PATH="ffmpeg"
FFPROBE_PATH="ffprobe"
# Conversational timing (all jittered ±AUDIO_GAP_JITTER so no two gaps match)
AUDIO_PAUSE_NONE_MS="80"        # quick reactions / comebacks
AUDIO_PAUSE_BEAT_MS="300"       # normal turn-taking
AUDIO_PAUSE_BREATH_MS="650"     # thought pivots
AUDIO_PAUSE_LONG_MS="1100"      # dramatic beats
AUDIO_SEGMENT_GAP_MS="850"      # between script segments
AUDIO_TOPIC_GAP_MS="1200"       # before a new topic
AUDIO_INTERRUPT_OVERLAP_MS="320" # how far an interruption bites into the previous line
AUDIO_GAP_JITTER="0.35"
# Shared acoustic space & production
AUDIO_ROOM_TONE_DB="-58"        # continuous room-tone bed; <=-100 disables
AUDIO_STEREO_SPREAD="0.14"      # hosts seated slightly left/right; 0 = mono-centered
AUDIO_MUSIC_CROSSFADE_MS="900"  # intro/outro music crossfade
AUDIO_QA_STRICT="false"         # true = fail the stitch job if human-ness QA fails
# Script generation delivery
SCRIPT_GEN_TEMPERATURE="0.85"
SCRIPT_GEN_MAX_TOKENS="16000"
# Optional: use a stronger model just for script WRITING (dialogue quality is
# extremely model-sensitive). Falls back to LLM_PROVIDER / its default model.
SCRIPT_LLM_PROVIDER=""
SCRIPT_LLM_MODEL=""
# VERIFICATION model (self-verify grounding rewrites + the semantic fact-check
# reviewer): structured grading against supplied evidence, so it runs on a
# cheaper model than the writer. Defaults to claude-sonnet-5 when the chain
# resolves to Anthropic; override here.
VERIFY_LLM_PROVIDER=""
VERIFY_MODEL=""
# Extra max_tokens cap headroom for adaptive-thinking models (thinking tokens
# count against max_tokens; without headroom long thinking truncates JSON).
LLM_THINKING_HEADROOM_TOKENS="8192"

# Security
TRUST_PROXY="true"
COOKIE_SECURE="false"
# Content sourcing quality
CONTENT_GATE_MODE="block"        # block | warn — refuse to write episodes on weak material
CONTENT_GATE_MIN="50"            # minimum average topic talkability (0-100)
TOPIC_MIN_TALKABILITY="35"       # auto-select skips topics scoring below this
RESEARCH_PROVIDER="exa"          # exa | stub — web research for brief enrichment
EXA_API_KEY="your-exa-api-key"
# Anthropic (script writing on Claude)
ANTHROPIC_API_KEY="your-anthropic-api-key"
ANTHROPIC_MODEL="claude-opus-4-8"

# Recurring podcast auto-generation (PART 5 of podcast-creation system)
# Daily time + timezone the scheduler enqueues episodes for recurring
# podcasts due that weekday. Global setting, not per-podcast.
RECURRING_GENERATION_TIME="06:00"
RECURRING_GENERATION_TZ="America/Chicago"
