# Database Configuration
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/takemachine?schema=public&connect_timeout=2"

# Redis Configuration (For BullMQ)
REDIS_URL="redis://localhost:6379"

# S3-Compatible Object Storage
STORAGE_PROVIDER="stub"
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY_ID="minioadmin"
S3_SECRET_ACCESS_KEY="minioadmin"
S3_BUCKET_NAME="takemachine-audio"
S3_REGION="us-east-1"
S3_PUBLIC_BASE_URL="http://localhost:9000/takemachine-audio"

# Provider Configurations
LLM_PROVIDER="stub"
OPENAI_API_KEY="your-openai-api-key"
OPENAI_MODEL="gpt-4o-mini"
ANTHROPIC_API_KEY="your-anthropic-api-key"
ANTHROPIC_MODEL="claude-3-5-sonnet-latest"

TTS_PROVIDER="stub"
ELEVENLABS_API_KEY="your-elevenlabs-api-key"
CARTESIA_API_KEY="your-cartesia-api-key"

SPORTS_PROVIDER="stub"
SPORTSDATAIO_API_KEY="your-sportsdataio-api-key"
THEODDSAPI_API_KEY="your-theoddsapi-api-key"
RSS_NEWS_FEEDS="https://www.espn.com/espn/rss/news"

# Podcast RSS & Feed Configurations
PODCAST_TITLE="Take Machine"
PODCAST_DESCRIPTION="AI-powered sports debate podcasts built from approved, fact-checked sports research."
PODCAST_LANGUAGE="en-us"
PODCAST_AUTHOR="Take Machine"
PODCAST_OWNER_NAME="Take Machine"
PODCAST_OWNER_EMAIL="owner@takemachine.com
PODCAST_SITE_URL="http://localhost:3000"
PODCAST_RSS_URL="http://localhost:3000/rss"
PODCAST_IMAGE_URL="http://localhost:3000/storage/podcast-cover.jpg"
PODCAST_CATEGORY="Sports"
PODCAST_SUBCATEGORY="Sports News"
PODCAST_EXPLICIT="false"
PODCAST_COPYRIGHT="Copyright Take Machine"
PODCAST_TTL="60"
RSS_INCLUDE_TRANSCRIPT_LINK="true"
RSS_INCLUDE_SHOW_NOTES="true"
RSS_PREVIEW_TOKEN="super-secret-preview-token"

# Media
FFMPEG_PATH="ffmpeg"
FFPROBE_PATH="ffprobe"
# Conversational timing (all jittered ±AUDIO_GAP_JITTER so no two gaps match)
AUDIO_PAUSE_NONE_MS="80"        # quick reactions / comebacks
AUDIO_PAUSE_BEAT_MS="300"       # normal turn-taking
AUDIO_PAUSE_BREATH_MS="650"     # thought pivots
AUDIO_PAUSE_LONG_MS="1100"      # dramatic beats
AUDIO_SEGMENT_GAP_MS="850"      # between script segments
AUDIO_TOPIC_GAP_MS="1200"       # before a new topic
AUDIO_INTERRUPT_OVERLAP_MS="320" # how far an interruption bites into the previous line
AUDIO_GAP_JITTER="0.35"
# Shared acoustic space & production
AUDIO_ROOM_TONE_DB="-58"        # continuous room-tone bed; <=-100 disables
AUDIO_STEREO_SPREAD="0.14"      # hosts seated slightly left/right; 0 = mono-centered
AUDIO_MUSIC_CROSSFADE_MS="900"  # intro/outro music crossfade
AUDIO_QA_STRICT="false"         # true = fail the stitch job if human-ness QA fails
# Script generation delivery
SCRIPT_GEN_TEMPERATURE="0.85"
SCRIPT_GEN_MAX_TOKENS="16000"

# Security
TRUST_PROXY="true"
COOKIE_SECURE="false"