# Database Configuration
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/takemachine?schema=public&connect_timeout=2"

# Redis Configuration (For BullMQ)
REDIS_URL="redis://localhost:6379"

# S3-Compatible Object Storage
STORAGE_PROVIDER="stub"
S3_ENDPOINT="http://localhost:9000" # Local minio or AWS S3 endpoint
S3_ACCESS_KEY_ID="minioadmin"
S3_SECRET_ACCESS_KEY="minioadmin"
S3_BUCKET_NAME="takemachine-audio"
S3_REGION="us-east-1"

# Provider Configurations
# LLM Provider: 'openai' | 'anthropic' | 'stub'
LLM_PROVIDER="stub"
OPENAI_API_KEY="your-openai-api-key"
OPENAI_MODEL="gpt-4o-mini"
ANTHROPIC_API_KEY="your-anthropic-api-key"
ANTHROPIC_MODEL="claude-3-5-sonnet-latest"

# TTS Provider: 'elevenlabs' | 'cartesia' | 'stub'
TTS_PROVIDER="stub"
ELEVENLABS_API_KEY="your-elevenlabs-api-key"
CARTESIA_API_KEY="your-cartesia-api-key"

# Sports Data Provider: 'sportsdataio' | 'oddsapi' | 'stub'
SPORTS_PROVIDER="stub"
SPORTSDATAIO_API_KEY="your-sportsdataio-api-key"
THEODDSAPI_API_KEY="your-theoddsapi-api-key"
RSS_NEWS_FEEDS="https://www.espn.com/espn/rss/news"

# Next.js Port (optional)
PORT=3000
